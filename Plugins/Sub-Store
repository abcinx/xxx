#!name=Sub-Store
#!desc=高级订阅管理工具.
#!openUrl=https://sub.store
#!icon=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Icons/Sub-Store.png

[Argument]
cron=input, "55 23 * * *", tag=定时参数, desc=这里需要输入符合CRON表达式的参数

[Rule]
DOMAIN,sub-store.vercel.app,PROXY

[MITM]
hostname=sub.store

[Script]
http-request ^https?:\/\/sub\.store\/((download)|api\/(preview|sync|(utils\/node-info))) script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/sub-store-1.min.js, requires-body=true, timeout=120, tag=Sub-Store Core
http-request ^https?:\/\/sub\.store script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/sub-store-0.min.js, requires-body=true, timeout=120, tag=Sub-Store Simple

cron {cron} script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/cron-sync-artifacts.min.js, timeout=120, tag=Sub-Store Sync
