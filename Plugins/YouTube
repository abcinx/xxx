#!name=Youtube
#!desc=去除广告，功能增强！
#!icon = https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Icons/YouTube.PNG
[Rule]
AND,((DOMAIN-SUFFIX, googlevideo.com), (PROTOCOL, QUIC)),REJECT
AND,((DOMAIN-SUFFIX, youtubei.googleapis.com), (PROTOCOL, QUIC)),REJECT
[URL Rewrite]
^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad reject-200
[Script]
http-response ^https?:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch) requires-body=1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/youtube.response.js
[MITM]
hostname = *.googlevideo.com, youtubei.googleapis.com
