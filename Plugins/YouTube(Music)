#!name=Youtube(Music)
#!desc=去除广告，功能增强！
#!icon=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Icons/YouTube.PNG
#!date=2026-04-15

[Argument]
blockUpload=switch, false, true, tag=隐藏(+), desc=隐藏YouTube底栏正中间的(+)
blockShorts=switch, false, true, tag=隐藏(Shorts), desc=隐藏YouTube底栏的(Shorts)
blockImmersive=switch, false, true, tag=隐藏(选段), desc=隐藏YouTube Music底栏的(选段)

[Rule]
AND, ((DOMAIN-SUFFIX, googlevideo.com), (PROTOCOL, QUIC)), REJECT
AND, ((DOMAIN-SUFFIX, youtubei.googleapis.com), (PROTOCOL, QUIC)), REJECT

[Rewrite]
^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad reject-200

[Script]
http-response ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$ script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/YouTube(Music)Enhance.js, requires-body=true, binary-body-mode=true, argument=[{blockUpload},{blockShorts},{blockImmersive}], tag=Youtube(Music)Enhance

[MitM]
hostname=*.googlevideo.com, youtubei.googleapis.com
