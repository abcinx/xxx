#!name=Spotify Lite Clean
#!desc=轻量优化：减少广告请求 + 提升稳定性（不破解 Premium）
#!date=2026.05.05

[Rule]
# 禁用 QUIC，避免 HTTP/3 干扰 MITM
AND,((DOMAIN-SUFFIX,spotify.com),(PROTOCOL, QUIC)),REJECT

# 广告/埋点域名（相对安全）
DOMAIN,aet.spotify.com,REJECT
DOMAIN,ads.spotify.com,REJECT

[Rewrite]
# 防缓存，确保响应可被修改
^https:\/\/spclient\.wg\.spotify\.com\/.* header-del if-none-match

# 屏蔽部分广告相关接口（温和版）
^https:\/\/spclient\.wg\.spotify\.com\/ads\/.* reject

[Mitm]
hostname = spclient.wg.spotify.com
