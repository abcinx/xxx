#!name=Spotify
#!desc=去除广告，功能增强！
#!icon=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Icons/Spotify.PNG
#!date=2026-04-15

[Rule]
# 1. 强制禁止 QUIC，确保流量走拦截通道
AND,((DOMAIN-SUFFIX, spotify.com), (PROTOCOL, QUIC)),REJECT
# 2. 屏蔽广告追踪与日志上报
DOMAIN, ads-fa.spotify.com, REJECT
DOMAIN, analytics.spotify.com, REJECT
DOMAIN, crashdump.spotify.com, REJECT
DOMAIN, log.spotify.com, REJECT

[Rewrite]
# 移除缓存验证，确保脚本始终生效
^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com)\/user-customization-service\/v1\/customize header-del if-none-match
# 屏蔽会员中心冗余界面
^https:\/\/.*-spclient\.spotify\.com\/pam-view-service\/ reject-dict
# 屏蔽 AI DJ
^https:\/\/.*-spclient\.spotify\.com\/.*37i9dQZF1EYkqdzj48dyYq reject-dict

[Script]
# 广告过滤脚本
http-request ^https:\/\/(.*-spclient\.spotify\.com|spclient\.wg\.spotify\.com)\/gabo-receiver-service script-path=https://raw.githubusercontent.com/Amlabort/MY_clash/refs/heads/main/files/lpx/js/spot-gabo.js, timeout=10, tag=Spotify_Ads
# 核心功能解锁脚本 (Protobuf)
http-response ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)(\?.*)?$ script-path=https://raw.githubusercontent.com/Amlabort/MY_clash/refs/heads/main/files/lpx/js/spot-proto-eevee.js, requires-body=true, binary-body-mode=true, timeout=10, tag=Spotify_Unlock

[Mitm]
hostname = spclient.wg.spotify.com, *-spclient.spotify.com
