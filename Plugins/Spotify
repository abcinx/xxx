[Rule]
AND,((DOMAIN-SUFFIX,spotify.com),(PROTOCOL, QUIC)),REJECT
DOMAIN,aet.spotify.com,REJECT

[Rewrite]
^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/user-customization-service\/v1\/customize header-del if-none-match
^https:\/\/(spclient\.wg|.*-spclient)\.spotify\.com(:443)?\/pendragon reject-dict

[Mitm]
hostname = spclient.wg.spotify.com, *spclient.spotify.com

[Script]
http-request ^https:\/\/(.*-spclient\.spotify\.com(:443)?|spclient\.wg\.spotify\.com)\/gabo-receiver-service script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/spot-gabo.js,timeout=10,tag=spotify-gabo
http-response ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)(\?.*)?$ script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/spot-proto-ev3.js,requires-body=true,binary-body-mode=true,timeout=10,tag=Ev3_spotifyProto

