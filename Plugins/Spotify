[Argument]
tab=switch, false, true, tag=移除底栏创建按钮, desc=此开关控制是否移除底栏创建按钮
useractivity=switch, true, false, tag=启用Apple设备接力, desc=此开关控制是否使用Apple设备接力

[Rule]
AND,((DOMAIN-SUFFIX, spotify.com), (PROTOCOL, QUIC)),REJECT

[Rewrite]
^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/user-customization-service\/v1\/customize header-del if-none-match

^https:\/\/.*-spclient\.spotify\.com(:443)?\/pam-view-service\/ reject-dict

^https:\/\/.*-spclient\.spotify\.com\/.*37i9dQZF1EYkqdzj48dyYq reject-dict

[Script]
http-request ^https:\/\/(.*-spclient\.spotify\.com(:443)?|spclient\.wg\.spotify\.com)\/gabo-receiver-service script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/Spotify-gabo.js, timeout=10, tag=spotify-gabo

http-response ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)(\?.*)?$ script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/Spotify-protobuf.js, requires-body=true, binary-body-mode=true, timeout=10, tag=Ev_spotifyProto

[Mitm]
hostname = spclient.wg.spotify.com, *spclient.spotify.com
