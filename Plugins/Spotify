http-response ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)(\?.*)?$ script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/spot-proto-ev3.js, requires-body=true, binary-body-mode=true, timeout=10, tag=Ev_spotifyProto

[Mitm]
