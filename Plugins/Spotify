#!name=Spotify
#!desc=去除广告，功能增强！
#!icon=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Icons/Spotify.PNG
#!date=2026-04-15

[Rewrite]
# 1. 强制刷新用户配置数据
^https:\/\/(spclient\.wg|.*-spclient)\.spotify\.com\/user-customization-service\/v1\/customize header-del if-none-match

# 2. 屏蔽广告、上报、AI DJ 及冗余服务 (合并正则提升性能)
^https:\/\/(.*-spclient|spclient\.wg)\.spotify\.com(?::443)?\/(pendragon|capping-api|partner-|pam-view-service|social-connect\/v.\/sessions) reject-dict

# 3. 屏蔽特定 AI DJ 内容
^https:\/\/spclient\.wg\.spotify\.com\/metadata\/4\/track\/37i9dQZF1EYkqdzj48dyYq reject-dict

[Script]
# Gabo 服务处理 (广告/追踪)
http-request ^https:\/\/(.*-spclient|spclient\.wg)\.spotify\.com\/gabo-receiver-service script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/Spotify-gabo.js, timeout=10, tag=Spotify-gabo

# 视图层数据处理 (艺术家/专辑)
http-request ^https:\/\/(spclient\.wg|.*-spclient)\.spotify\.com\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/ script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/Spotify-json.js, timeout=10, tag=Spotify-json

# 核心协议修改 (解锁 UI/切歌限制) - 采用 Eevee 逻辑
http-response ^https:\/\/(spclient\.wg|.*-spclient)\.spotify\.com\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)(\?.*)?$ script-path=https://raw.githubusercontent.com/abcinx/xxx/refs/heads/main/Scripts/Spotify-proto.js, requires-body=true, binary-body-mode=true, timeout=10, tag=Spotify-proto

[Mitm]
# 修正后的主机名匹配，覆盖所有 Spotify 相关业务子域名
hostname = spclient.wg.spotify.com, *-spclient.spotify.com
